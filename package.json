{
  "name": "loja-plataforma",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm run dev --workspace=api",
    "dev:admin": "npm run dev --workspace=web-admin",
    "dev:loja": "npm run dev --workspace=web-loja",
    "build:all": "npm run build --workspaces",
    "db:generate": "npm run db:generate --workspace=api",
    "db:migrate": "npm run db:migrate --workspace=api"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
